<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="index.css" />
    <link rel="stylesheet" href="base.css" />
    <link rel="stylesheet" href="app.css" />
    <title>Exercise APP - NEW</title>
  </head>
  <body>
    <section class="todoapp">      
      <section>
        <nav class="nav">
          <ul>
            <li class="user"><%= user.name || user.username || user.email %></li>
            <li>
              <form action="logout" method="post">
                <button class="logout" type="submit">Sign out</button>
              </form>
            </li>
          </ul>
        </nav>
        <header class="header">
          <h1>Home Page</h1>
          <form action="">
            <input class="new-todo" title="name" placeholder="Exercise Activity here" autofocus>
            <input type="hidden" name="filter">
          </form>
        </header>
        <section class="main">
          <form action="">            
            <input class="new-todo-input">
            <input type="checkbox">
            <label for="">Mark all as Complete</label>
          </form>
          <form action="">
           <button class="submit" >Clear Completed</button>
         </form>
        </section>
    </section>
    <footer class="footer">
      <ul class="filters">
        <li>
          <a href="">all</a>
        </li>
        <li>
          <a href="">Active</a>
        </li>
        <li>
          <a href="">Completed</a>
        </li>       
      </ul>
     
    </footer>
  </body>
</html>
